{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "MESC_F405RG: preflight",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/preflight_f405rg.sh",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "MESC_F405RG: compile",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/build_f405rg.sh",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "MESC_F405RG: upload",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/upload_f405rg.sh",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "MESC_F405RG: compile + upload",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/build_and_upload_f405rg.sh",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "MESC_F405RG: build",
      "dependsOrder": "sequence",
      "dependsOn": [
        "MESC_F405RG: compile"
      ],
      "problemMatcher": []
    },
    {
      "label": "MESC_F405RG: build + upload",
      "dependsOrder": "sequence",
      "dependsOn": [
        "MESC_F405RG: compile + upload"
      ],
      "problemMatcher": []
    },
    {
      "label": "MESC_F405RG: clean",
      "type": "shell",
      "command": "make",
      "args": [
        "-C",
        "MESC_F405RG/Debug",
        "clean"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
